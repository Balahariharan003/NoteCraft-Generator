{
  "manifest_version": 3,
  "name": "MoM Generator",
  "version": "1.0",
  "description": "Automatically generate Minutes of Meeting from Google Meet / Zoom",

  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "MoM Generator"
  },

  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}