{
  "manifest_version": 3,
  "name": "MoM Generator",
  "version": "1.0",
  "description": "Automatically generate Minutes of Meeting from Google Meet",
  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}